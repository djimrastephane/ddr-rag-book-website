---
// Demo / Screenshots page. EDIT: replace placeholders by passing src="/screenshots/..."
// after dropping real images into public/screenshots/.
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScreenshotCard from "../components/ScreenshotCard.astro";
import CTAButton from "../components/CTAButton.astro";
import { site } from "../data/site";
---

<Base title="Demo" description="Screenshots and a walkthrough of the DDR RAG companion app.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="demo"
      heading="See the system in action"
      lead="The book companion app is a Streamlit app you build chapter by chapter over the Utah FORGE sample archive: hybrid retrieval (BM25 + embeddings), cited answers, and optional local LLM generation via Ollama. It reuses the book's own code from Chapters 4, 5, and 9 — nothing here is reimplemented — run it yourself in minutes."
    />
    <div class="mt-6 flex flex-wrap gap-3">
      <CTAButton href="/project/">How to run it locally</CTAButton>
      <CTAButton href={`${site.repoUrl}/tree/main/book/app`} variant="ghost">App source code</CTAButton>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <ScreenshotCard
        src="/screenshots/app_landing.jpg"
        title="Ask a question"
        caption="Pick a sample engineering question or type your own, choose top-k, and optionally generate an answer with a local Ollama model."
      />
      <ScreenshotCard
        src="/screenshots/app_answer.jpg"
        title="Evidence-backed answer"
        caption="A real answer generated locally by qwen2.5:7b-instruct, with the source report cited — and an honest note when the evidence doesn't fully answer the question."
      />
      <ScreenshotCard
        src="/screenshots/app_transparency.jpg"
        title="Retrieved evidence"
        caption="Every matched report shown with its score, date, excerpt, and why it was retrieved — evidence first, answer second."
      />
      <ScreenshotCard
        src="/screenshots/app_stuck_pipe.jpg"
        title="Ask your own question"
        caption="A custom question — 'What happened around the stuck pipe event?' — answered from the report that logged the lost tool face and stuck assembly, citation included."
      />
    </div>

    <div class="mt-12 max-w-3xl">
      <SectionHeader
        kicker="example"
        heading="A typical interaction"
        lead="Five steps, every one of them visible to the reader — not just a question and an answer."
      />
      <div class="mt-6 grid gap-3">
        <div class="rounded-lg border border-line bg-panel p-4">
          <p class="font-mono text-[11px] uppercase tracking-wide text-accent">1 · Question</p>
          <p class="mt-1 font-mono text-sm text-white">What problems were reported while running the 9-5/8" casing?</p>
        </div>
        <div class="rounded-lg border border-line bg-panel p-4">
          <p class="font-mono text-[11px] uppercase tracking-wide text-accent">2 · Retrieved reports</p>
          <p class="mt-1 font-mono text-xs text-slate-400">
            DDR-042 (score 0.91) · DDR-043 (score 0.87) · DDR-039 (score 0.74)
          </p>
        </div>
        <div class="rounded-lg border border-line bg-panel p-4">
          <p class="font-mono text-[11px] uppercase tracking-wide text-accent">3 · Highlighted evidence</p>
          <p class="mt-1 font-mono text-xs leading-relaxed text-slate-400">
            "…ran into <mark class="rounded bg-accent/25 px-1 text-slate-200">obstruction at 6,210 ft, required wiper trip</mark> before resuming casing run…" — DDR-042, ops summary
          </p>
        </div>
        <div class="rounded-lg border border-accent/40 bg-panel p-4">
          <p class="font-mono text-[11px] uppercase tracking-wide text-accent">4 · Generated answer (local LLM)</p>
          <p class="mt-1 font-mono text-sm text-slate-200">
            The reports describe an obstruction encountered during the casing run, requiring a wiper trip
            before continuing, followed by circulation losses treated with LCM.
          </p>
        </div>
        <div class="rounded-lg border border-line bg-panel p-4">
          <p class="font-mono text-[11px] uppercase tracking-wide text-accent">5 · Source citation</p>
          <p class="mt-1 font-mono text-xs text-slate-400">
            <span class="text-accent">[DDR-042, ops summary]</span> · <span class="text-accent">[DDR-043, mud report]</span>
            — click through to the original report text.
          </p>
        </div>
      </div>
      <p class="mt-3 text-xs text-slate-500">Illustrative example — run the app on the sample archive to see real output.</p>
    </div>
  </section>
</Base>
