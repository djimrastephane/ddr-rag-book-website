---
// Demo / Screenshots page. EDIT: replace placeholders by passing src="/screenshots/..."
// after dropping real images into public/screenshots/.
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScreenshotCard from "../components/ScreenshotCard.astro";
import CTAButton from "../components/CTAButton.astro";
import { site } from "../data/site";
---

<Base title="Demo" description="Screenshots and a walkthrough of the DDR RAG companion app.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="demo"
      heading="See the system in action"
      lead="The book companion app is a Streamlit app you build chapter by chapter over the Utah FORGE sample archive: hybrid retrieval (BM25 + embeddings), cited answers, and optional local LLM generation via Ollama. Every line of it is explained in Chapters 5–10 — run it yourself in minutes."
    />
    <div class="mt-6 flex flex-wrap gap-3">
      <CTAButton href="/project/">How to run it locally</CTAButton>
      <CTAButton href={`${site.repoUrl}/tree/main/book/app`} variant="ghost">App source code</CTAButton>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <ScreenshotCard title="Ask a question" caption="Natural-language questions over the whole report archive." />
      <ScreenshotCard title="Hybrid retrieval results" caption="BM25 and semantic hits fused and ranked, each with report and date." />
      <ScreenshotCard title="Evidence-backed answer" caption="Generated answer with inline citations back to source passages." />
      <ScreenshotCard title="Source passage view" caption="Click any citation to read the original report text it came from." />
    </div>

    <div class="mt-12 max-w-3xl">
      <SectionHeader kicker="example" heading="A typical interaction" />
      <div class="mt-6 rounded-lg border border-line bg-panel p-5 font-mono text-sm leading-relaxed text-slate-300">
        <p class="text-slate-500"># question</p>
        <p class="text-white">&gt; What problems were reported while running the 9-5/8" casing?</p>
        <p class="mt-3 text-slate-500"># answer (local LLM, citations attached)</p>
        <p>
          The reports describe an obstruction encountered during the casing run, requiring a wiper trip
          before continuing <span class="text-accent">[DDR-042, ops summary]</span>, followed by circulation
          losses treated with LCM <span class="text-accent">[DDR-043, mud report]</span>.
        </p>
        <p class="mt-3 text-xs text-slate-500">Illustrative example — run the app on the sample archive to see real output.</p>
      </div>
    </div>
  </section>
</Base>
