---
// Contact page — simple mailto + links, no backend needed for v1.
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { site } from "../data/site";
---

<Base title="Contact" description="Get in touch about the book, the companion project, speaking, or consulting.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="contact"
      heading="Get in touch"
      lead="Questions about the book, feedback on the companion project, speaking, or consulting on industrial RAG systems — I read everything."
    />
    <div class="mt-8 grid max-w-3xl gap-4 sm:grid-cols-2">
      <a href={`mailto:${site.email}`} class="card-lift rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
        <p class="font-semibold text-white">Email</p>
        <p class="mt-1 font-mono text-sm text-accent">{site.email}</p>
        <p class="mt-2 text-xs text-slate-400">Best for book feedback, speaking, and consulting.</p>
      </a>
      <a href={`${site.repoUrl}/discussions`} class="card-lift rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
        <p class="font-semibold text-white">GitHub Discussions</p>
        <p class="mt-1 font-mono text-sm text-accent">{site.repoName}/discussions</p>
        <p class="mt-2 text-xs text-slate-400">Best for technical questions — answers help other readers too.</p>
      </a>
      <a href={`${site.repoUrl}/issues`} class="card-lift rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
        <p class="font-semibold text-white">GitHub Issues</p>
        <p class="mt-1 font-mono text-sm text-accent">{site.repoName}/issues</p>
        <p class="mt-2 text-xs text-slate-400">Found a bug in the code or an error in the book? Open an issue.</p>
      </a>
      {
        site.linkedin && (
          <a href={site.linkedin} class="card-lift rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
            <p class="font-semibold text-white">LinkedIn</p>
            <p class="mt-1 font-mono text-sm text-accent">Connect</p>
          </a>
        )
      }
    </div>
  </section>
</Base>
