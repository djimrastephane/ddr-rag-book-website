---
// Blog index — lists all Markdown posts in this folder, newest first.
// To add a post: create src/pages/blog/my-post.md with the same frontmatter
// shape as the existing posts. It appears here automatically.
import Base from "../../layouts/Base.astro";
import SectionHeader from "../../components/SectionHeader.astro";

const posts = Object.values(
  import.meta.glob("./*.md", { eager: true })
) as any[];
posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<Base title="Blog" description="Notes on industrial RAG, retrieval, and building AI systems for drilling data.">
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="blog"
      heading="Industrial AI, from the field"
      lead="Notes on retrieval, traceability, and lessons learned building RAG systems for drilling reports."
    />

    <!-- EDIT: Buttondown username below — change if you ever switch accounts -->
    <div class="mt-8 max-w-3xl rounded-lg border border-accent/30 bg-panel p-5">
      <p class="font-semibold text-white">Get new posts by email</p>
      <p class="mt-1 text-sm text-slate-400">
        New articles on retrieval, traceability, and industrial RAG — no spam, unsubscribe anytime.
      </p>
      <form
        action="https://buttondown.email/api/emails/embed-subscribe/stephanedjimra"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.email/stephanedjimra', 'popupwindow')"
        class="mt-3 flex max-w-sm gap-2"
      >
        <label class="sr-only" for="bd-email-blog">Email address</label>
        <input
          id="bd-email-blog"
          type="email"
          name="email"
          required
          placeholder="you@email.com"
          class="w-full min-w-0 rounded-md border border-line bg-ink px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-accent focus:outline-none"
        />
        <button
          type="submit"
          class="shrink-0 rounded-md bg-accent px-4 py-2 text-sm font-semibold text-white hover:bg-amber-400 dark:text-[#0b1118]"
        >
          Subscribe
        </button>
      </form>
    </div>

    <div class="mt-8 grid max-w-3xl gap-4">
      {
        posts.map((post) => (
          <a href={post.url} class="card-lift rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
            <p class="font-mono text-xs text-slate-500">{post.frontmatter.date} · {post.frontmatter.readingTime}</p>
            <h2 class="mt-1 font-semibold text-white">{post.frontmatter.title}</h2>
            <p class="mt-2 text-sm text-slate-400">{post.frontmatter.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</Base>
