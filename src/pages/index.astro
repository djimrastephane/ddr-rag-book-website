---
import Base from "../layouts/Base.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FeatureCard from "../components/FeatureCard.astro";
import CTAButton from "../components/CTAButton.astro";
import ScreenshotCard from "../components/ScreenshotCard.astro";
import PipelineFlow from "../components/PipelineFlow.astro";
import {
  site,
  pipeline,
  builds,
  whyItMatters,
  whyItMattersIntro,
  technologies,
  metrics,
  homeCareerGlance,
} from "../data/site";
---

<Base>
  <!-- ================= HERO ================= -->
  <section class="border-b border-line">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 md:grid-cols-[1fr_300px] md:py-24">
      <div>
      <p class="animate-rise font-mono text-xs font-semibold uppercase tracking-widest text-accent">
        {site.tagline} — the official project site
      </p>
      <h1 class="animate-rise mt-4 max-w-3xl text-4xl font-bold leading-tight text-white md:text-5xl">
        Build Industrial AI Systems from Daily Drilling Reports
      </h1>
      <p class="animate-rise-delay mt-5 max-w-2xl text-xl font-semibold text-white">
        Turn years of Daily Drilling Reports into searchable engineering knowledge.
      </p>
      <p class="animate-rise-delay mt-3 max-w-2xl text-lg text-slate-300">{site.description}</p>
      <div class="animate-rise-delay mt-8 flex flex-wrap gap-3">
        <CTAButton href={site.liveBookUrl}>Read the Book</CTAButton>
        <CTAButton href={site.repoUrl} variant="ghost">View GitHub</CTAButton>
        <CTAButton href="/demo/" variant="ghost">See Demo</CTAButton>
      </div>
      <!-- Credibility metrics — small badges, verifiable values only -->
      <div class="animate-rise-delay mt-5 flex flex-wrap gap-2">
        {
          metrics.map((m) => (
            <span class="rounded-full border border-line bg-panel px-2.5 py-1 font-mono text-[11px] text-slate-400">
              {m}
            </span>
          ))
        }
      </div>
      <!-- Subtle document/terminal visual -->
      <div class="mt-12 max-w-2xl rounded-lg border border-line bg-panel p-4 font-mono text-xs leading-relaxed text-slate-400">
        <p class="text-slate-500"># DDR 2019-05-14 — raw report text</p>
        <p>06:00–09:30 POOH w/ BHA #4. Tight hole @ 7,842 ft, worked pipe...</p>
        <p class="mt-2 text-slate-500"># your question</p>
        <p class="text-white">&gt; When did we last see stuck pipe symptoms in this section?</p>
        <p class="mt-2 text-slate-500"># traceable answer</p>
        <p><span class="text-accent">Tight hole with overpull was reported at 7,842 ft</span> [DDR 2019-05-14, ops summary, lines 12–14]</p>
      </div>
      </div>
      <a href="/book/" class="animate-rise-delay mx-auto w-56 md:w-full" aria-label="About the book">
        <img
          src="/book-cover.jpg"
          alt="Book cover: Building Industrial RAG Systems from Daily Drilling Reports"
          class="card-lift w-full rounded-lg border border-line shadow-xl"
        />
      </a>
    </div>
  </section>

  <!-- ================= PROBLEM ================= -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="the problem"
      heading="Years of operational knowledge, trapped in PDFs"
      lead="Every well generates hundreds of Daily Drilling Reports: lessons on stuck pipe, losses, NPT, and what actually worked. But they live in scanned files, inconsistent formats, and unstructured text — and keyword search fails because crews describe the same event as 'stuck pipe' one day and 'tight hole' or 'high torque' the next. Same event, invisible to search."
    />
  </section>

  <!-- ================= SOLUTION ================= -->
  <section class="border-y border-line bg-panel/40">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader
        kicker="the solution"
        heading="A complete pipeline, built one chapter at a time"
        lead="The book walks you through every stage — no prior programming experience assumed, everything running locally on your laptop."
      />
      <div class="mt-8 overflow-x-auto pb-2">
        <PipelineFlow />
      </div>
      <p class="mt-3 text-xs text-slate-500">
        The engineer makes the final call — the system's job is to surface evidence, not replace judgment.
      </p>
      <p class="mt-10 font-mono text-xs uppercase tracking-wide text-slate-500">Full pipeline, step by step</p>
      <ol class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {
          pipeline.map((step, i) => (
            <li class="flex items-center gap-3 rounded-md border border-line bg-ink px-4 py-2.5 text-sm text-slate-300">
              <span class="font-mono text-xs text-accent">{String(i + 1).padStart(2, "0")}</span>
              {step}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ================= WHAT YOU'LL BUILD ================= -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader kicker="what you'll build" heading="Working systems from real drilling reports" />
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {builds.map((b) => <FeatureCard title={b.title} text={b.text} />)}
    </div>

    <!-- Real screenshots of the companion app, so readers see proof, not just a promise -->
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      <ScreenshotCard
        src="/screenshots/app_answer.jpg"
        title="A real cited answer"
        caption="Generated locally by qwen2.5:7b-instruct from the sample DDR archive, with the source report cited."
      />
      <ScreenshotCard
        src="/screenshots/app_transparency.jpg"
        title="The evidence behind it"
        caption="Every matched report shown with its match strength, date, and excerpt — evidence first, answer second."
      />
    </div>
    <p class="mt-4 text-center text-sm text-slate-400">
      <a href="/demo/" class="text-accent hover:underline">See the full demo →</a>
    </p>
  </section>

  <!-- ================= WHY IT MATTERS ================= -->
  <section class="border-y border-line bg-panel/40">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader
        kicker="why it matters"
        heading="Traceable answers engineers can trust"
        lead="In drilling operations, an unsourced answer is a liability. This book treats citations, local execution, and engineering review as core requirements — not afterthoughts."
      />
      <p class="mt-6 max-w-3xl text-sm leading-relaxed text-slate-300">{whyItMattersIntro}</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {whyItMatters.map((w) => <FeatureCard title={w.title} text={w.text} />)}
      </div>
    </div>
  </section>

  <!-- ================= BUILT WITH ================= -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <SectionHeader
      kicker="built with"
      heading="Open-source, local-first stack"
      lead="Hover any item for a plain-English explanation — no prior experience with these tools is assumed."
    />
    <div class="mt-6 flex flex-wrap gap-2">
      {
        technologies.map((t) => (
          <span
            title={t.what}
            class="cursor-help rounded-full border border-line bg-panel px-3 py-1 font-mono text-xs text-slate-300"
          >
            {t.name}
          </span>
        ))
      }
    </div>
  </section>

  <!-- ================= AUTHOR ================= -->
  <section class="border-y border-line bg-panel/40">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <SectionHeader
        kicker="the author"
        heading="Written from the rig floor and the notebook"
        lead="More than 17 years in completions, well intervention, stimulation and integrated well projects across eight countries, an MSc in Data Science, and a focus on practical industrial AI — building the tools that turn years of engineering reports into searchable, evidence-backed knowledge."
      />
      <!-- Career at a glance — short teaser only; full detail lives on /author/ -->
      <div class="mt-5 flex flex-wrap gap-2">
        {
          homeCareerGlance.map((c) => (
            <span class="rounded-full border border-line bg-ink px-3 py-1 font-mono text-xs text-slate-300">{c}</span>
          ))
        }
      </div>
      <div class="mt-6">
        <CTAButton href="/author/" variant="ghost">About the author</CTAButton>
      </div>
    </div>
  </section>

  <!-- ================= FINAL CTA ================= -->
  <section class="mx-auto max-w-6xl px-4 py-20 text-center">
    <h2 class="text-3xl font-bold text-white">Start building traceable AI for drilling reports.</h2>
    <p class="mx-auto mt-3 max-w-xl text-slate-400">
      The book is free to read online, the code is MIT-licensed, and everything runs on your laptop.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <CTAButton href={site.liveBookUrl}>Read the Book</CTAButton>
      <CTAButton href={site.repoUrl} variant="ghost">Star on GitHub</CTAButton>
    </div>
  </section>
</Base>
