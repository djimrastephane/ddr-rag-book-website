---
// Base layout: <head> with SEO/OG metadata, responsive nav, footer.
// Pages pass `title` and `description`; everything else is automatic.
import "../styles/global.css";
import { site, nav, futureSections } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.title}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const current = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <!-- EDIT: share card image — regenerate public/og.png if the title or cover changes -->
    <meta property="og:image" content={new URL("/og.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL("/og.png", Astro.site)} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <!-- Theme init: runs before paint to avoid a flash. Light is the default. -->
    <script is:inline>
      if (localStorage.theme === "dark") document.documentElement.classList.add("dark");
    </script>
  </head>
  <body class="min-h-screen font-sans antialiased">
    <header class="sticky top-0 z-50 border-b border-line bg-ink/90 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex items-baseline gap-2 font-mono text-sm font-bold tracking-tight text-white">
          <span class="text-accent">▙</span> {site.name}
        </a>
        <div class="flex items-center gap-2 md:order-last">
          <!-- Light/dark toggle -->
          <button
            id="theme-toggle"
            aria-label="Toggle light/dark mode"
            class="rounded-md border border-line p-1.5 text-slate-400 transition-colors hover:border-accent hover:text-accent"
          >
            <svg class="hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="4" /><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4" />
            </svg>
            <svg class="dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z" />
            </svg>
          </button>
        </div>
        <!-- Mobile toggle (CSS-only, no JS) -->
        <input type="checkbox" id="nav-toggle" class="peer hidden" />
        <label for="nav-toggle" class="cursor-pointer p-1 text-slate-300 md:hidden" aria-label="Toggle navigation">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </label>
        <nav
          class="absolute left-0 top-full hidden w-full flex-col gap-1 border-b border-line bg-ink px-4 pb-4 pt-2 peer-checked:flex md:static md:flex md:w-auto md:flex-row md:gap-5 md:border-0 md:bg-transparent md:p-0"
        >
          {
            nav.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "py-1 text-sm transition-colors hover:text-accent",
                  current === item.href ? "text-accent" : "text-slate-300",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main><slot /></main>

    <footer class="mt-20 border-t border-line">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-3">
        <div>
          <p class="font-mono text-sm font-bold text-white"><span class="text-accent">▙</span> {site.name}</p>
          <p class="mt-2 text-sm text-slate-400">{site.tagline}</p>
          <p class="mt-2 text-xs text-slate-500">Code: MIT · Book text: CC BY 4.0</p>
        </div>
        <div>
          <p class="text-sm font-semibold text-white">Project</p>
          <ul class="mt-2 space-y-1 text-sm text-slate-400">
            <li><a class="hover:text-accent" href={site.repoUrl}>GitHub repository</a></li>
            <li><a class="hover:text-accent" href={site.liveBookUrl}>Read the book online</a></li>
            <li><a class="hover:text-accent" href={`${site.repoUrl}/issues`}>Issues</a></li>
            <li><a class="hover:text-accent" href={`${site.repoUrl}/discussions`}>Discussions</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-white">Coming later</p>
          <!-- EDIT: futureSections in src/data/site.ts — remove items as they launch -->
          <ul class="mt-2 grid grid-cols-2 gap-x-4 gap-y-1 text-sm text-slate-500">
            {futureSections.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </div>
      <div class="border-t border-line py-4 text-center text-xs text-slate-500">
        © {new Date().getFullYear()} {site.authorName}. Built with Astro.
      </div>
    </footer>

    <script is:inline>
      // Theme toggle
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const dark = document.documentElement.classList.toggle("dark");
        localStorage.theme = dark ? "dark" : "light";
      });

      // Subtle scroll-reveal for sections and cards
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("reveal-in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll("main section, main article").forEach((el) => {
        el.classList.add("reveal");
        io.observe(el);
      });
    </script>
  </body>
</html>
