---
// Layout for Markdown blog posts (set via `layout:` in each post's frontmatter).
import Base from "./Base.astro";
import { site } from "../data/site";

const { frontmatter } = Astro.props;
// Frontmatter `date` is "YYYY-MM-DD"; ISO 8601 with a time is required for article:published_time.
const publishedTime = new Date(frontmatter.date + "T00:00:00Z").toISOString();
---

<Base
  title={frontmatter.title}
  description={frontmatter.description}
  article={{ publishedTime }}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: frontmatter.title,
      description: frontmatter.description,
      datePublished: publishedTime,
      author: { "@type": "Person", name: site.authorName, url: site.linkedin },
    })}
  />
  <article class="mx-auto max-w-3xl px-4 py-16">
    <p class="font-mono text-xs font-semibold uppercase tracking-widest text-accent">Blog</p>
    <h1 class="mt-2 text-3xl font-bold text-white">{frontmatter.title}</h1>
    <p class="mt-2 font-mono text-xs text-slate-500">
      By {site.authorName} · {frontmatter.date} · {frontmatter.readingTime}
    </p>
    <div
      class="prose-invert mt-8 space-y-4 leading-relaxed text-slate-300 [&_a]:text-accent [&_a]:underline [&_code]:font-mono [&_code]:text-sm [&_code]:text-amber-200 [&_h2]:mt-8 [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-white [&_li]:ml-5 [&_li]:list-disc [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-line [&_pre]:bg-panel [&_pre]:p-4"
    >
      <slot />
    </div>
    <p class="mt-12 border-t border-line pt-6 text-sm"><a href="/blog/" class="text-accent hover:underline">← All posts</a></p>
  </article>
</Base>
