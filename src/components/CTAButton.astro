---
// CTA button. variant: "primary" (amber) or "ghost" (outlined).
interface Props {
  href: string;
  variant?: "primary" | "ghost";
}
const { href, variant = "primary" } = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-block rounded-md px-5 py-2.5 text-sm font-semibold transition-colors",
    variant === "primary"
      ? "bg-accent text-[#ffffff] hover:bg-amber-400 dark:text-[#0b1118]"
      : "border border-line text-slate-200 hover:border-accent hover:text-accent",
  ]}
>
  <slot />
</a>
