---
// Compact chapter card for the TOC page; links to details + repo folder.
import type { Chapter } from "../data/site";
import { chapterUrl, bookChapterUrl } from "../data/site";

interface Props {
  chapter: Chapter;
}
const { chapter: c } = Astro.props;
---

<div class="card-lift flex gap-4 rounded-lg border border-line bg-panel p-5 hover:border-accent/50">
  <div class="font-mono text-2xl font-bold text-accent">{String(c.num).padStart(2, "0")}</div>
  <div class="min-w-0">
    <h3 class="font-semibold text-white">{c.title}</h3>
    <p class="mt-1 text-sm text-slate-400">{c.summary}</p>
    <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs">
      <a href={bookChapterUrl(c)} class="font-semibold text-accent hover:underline">Read this chapter →</a>
      <span class="font-mono text-slate-500">{c.keyScript}</span>
      <a href={chapterUrl(c)} class="font-mono text-accent hover:underline">{c.folder} ↗</a>
      <a href={`/chapters/#chapter-${c.num}`} class="text-slate-400 hover:text-accent">Learning guide →</a>
    </div>
  </div>
</div>
