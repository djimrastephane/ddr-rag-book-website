---
// The site's mark: a geometric drilling-derrick silhouette (legs, two
// cross-braces, base line), drawn as a single stroke in currentColor so it
// follows the accent color and light/dark theme automatically.
interface Props {
  size?: number;
  class?: string;
}
const { size = 20, class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d="M12 2 L6 21 M12 2 L18 21 M8.2 9 L15.8 9 M7.1 15 L16.9 15 M4 21 H20" />
</svg>
