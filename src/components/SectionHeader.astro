---
// Reusable section header: small mono kicker + heading + optional lead text.
interface Props {
  kicker: string;
  heading: string;
  lead?: string;
}
const { kicker, heading, lead } = Astro.props;
---

<div class="max-w-3xl">
  <p class="font-mono text-xs font-semibold uppercase tracking-widest text-accent">{kicker}</p>
  <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">{heading}</h2>
  {lead && <p class="mt-3 text-slate-300">{lead}</p>}
</div>
